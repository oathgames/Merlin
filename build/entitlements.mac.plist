<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- V8 JIT code pages. Electron 41 needs this for the renderer's JavaScript
         engine; the narrower `allow-jit` entitlement is preferred over the
         broader `disable-executable-page-protection`, which late-2024 Apple
         Notary started rejecting on new submissions. -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <!-- REGRESSION GUARD (2026-04-23): `com.apple.security.cs.disable-executable-page-protection`
         was removed here. Apple Notary began soft-rejecting submissions that
         carry it in late 2024 and is expected to hard-fail them in a future
         macOS release. The narrower `allow-jit` above is sufficient for V8
         on Electron 41 — do NOT re-add disable-executable-page-protection
         without first confirming (a) Apple has reversed the notary policy,
         and (b) allow-jit alone actually fails on the current Electron build
         (reproduce in a notarized DMG, not dev mode). See rsi-batch-1 task 2.4. -->
    <key>com.apple.security.cs.allow-dyld-environment-variables</key>
    <true/>
    <!-- Required by onnxruntime-node: the bundled native `.dylib`s are signed
         with a different Team ID than Merlin itself, so strict library
         validation refuses to load them. Removing this entitlement breaks
         embedding generation (clarify-intent routing, creative rubric scoring). -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
    <key>com.apple.security.inherit</key>
    <true/>
    <key>com.apple.security.network.client</key>
    <true/>
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>
    <key>com.apple.security.device.audio-input</key>
    <true/>
</dict>
</plist>
